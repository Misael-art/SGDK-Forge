// Neon color palette for visual effects
// 16 colors total (index 0 = transparent)

0x0000  // 0: Transparent
0x0000  // 1: Black
0x2222  // 2: Dark blue
0x4444  // 3: Medium blue
0x6666  // 4: Light blue
0x0444  // 5: Dark green
0x0888  // 6: Medium green
0x0CCC  // 7: Light green
0x4440  // 8: Dark red
0x8880  // 9: Medium red
0xCCC0  // 10: Light red
0x8888  // 11: Yellow
0x0AAA  // 12: Cyan
0xA0A0  // 13: Magenta
0xEEE0  // 14: White (will be animated)
0xEEE8  // 15: Light gray
