// Player sprite palette
// Simple 4-color sprite for the player ship

0x0000  // 0: Transparent
0x0000  // 1: Black (outline)
0x0EEE  // 2: Bright cyan (main body)
0x0888  // 3: Green (details)
0x0444  // 4: Dark blue (shadows)
0x0000  // 5: Unused
0x0000  // 6: Unused
0x0000  // 7: Unused
0x0000  // 8: Unused
0x0000  // 9: Unused
0x0000  // 10: Unused
0x0000  // 11: Unused
0x0000  // 12: Unused
0x0000  // 13: Unused
0x0000  // 14: Unused
0x0000  // 15: Unused
