;---------------------- Integer variable list ----------------------

; var(1):= 180 - Win state decider
; var(4):= 251 - Corte Soco Forte, 1002 - Corte Soco Forte, 1004 - Corte Soco Forte, 910 - Corte Soco Fraco, 272 - Corte Chute Forte Longe, 269 - Corte Soco Forte, 262 - Corte Chute Forte Longe
; var(7):= 1000, 1005, 1015, 1025, 1225, 3520
;var(10):= -2 - Override common states (use same number to override) :
;var(11):= -2 - Override common states (use same number to override) :
;var(12):= -2 - Override common states (use same number to override) :
;var(15):= -2 - Override common states (use same number to override) :
;var(16):= -2 - Override common states (use same number to override) :
;var(20):= 3200, -2 - Override common states (use same number to override) :
;var(35):= 0 - Stand
;var(40):= 3521
;var(41):= -2 - Override common states (use same number to override) :
;var(47):= 3500
;var(48):= 210 - Standing strong punch, 215, 230 - Standing light kick, 235 - Standing light kick, 240 - Standing strong kick, 245 - Standing strong kick, 250 - Standing CD, 300 - Crouching light punch, 310 - Crouching strong punch, 330 - Crouching light kick, 340 - Crouch Strong Kick, 400 - Jump Light Punch, 410 - Jump Strong Punch, 420, 430 - Jump Light Kick, 440 - Jump Strong Kick, 450 - Standing CD, 3200, 266 - Standing strong punch, 268 - Standing strong punch
;var(51):= -2 - Override common states (use same number to override) :
;var(52):= 245 - Standing strong kick, 250 - Standing CD, 300 - Crouching light punch, 1000, 1005, 1010, 1015, 1020, 1025, 1200, 1205, 1220, 1225, 1230, 1300, 1305, 1310, 1315, 1320, 1325, 1330, 1335, 3520, 270 - Standing strong punch, 260 - Standing strong punch, 265 - Standing strong punch, 267 - Standing strong punch, 266 - Standing strong punch, 268 - Standing strong punch

;---------------------- Float variable list ----------------------

;fvar(22):= -2 - Override common states (use same number to override) :



[Data]
;Amount of life to start with
;?????????
life = 1200
;attack power (more is stronger)
;??????
attack = 100
power = 3000
;defensive power (more is stronger)
;?????
defence = 100
;Percentage to increase defense everytime player is knocked down
fall.defence_up = 50
;Time which player lies down for, before getting up
liedown.time = 9
;Number of points for juggling
airjuggle = 15
;Default hit spark number for HitDefs
sparkno = 11
;Default guard spark number
guard.sparkno = 40
;1 to enable echo on KO
KO.echo = 0
;Volume offset (negative for softer)
volume = 255
;Variables with this index and above will not have their values
;reset to 0 between rounds or matches. There are 60 int variables,
;indexed from 0 to 59, and 40 float variables, indexed from 0 to 39.
;If omitted, then it defaults to 60 and 40 for integer and float
;variables repectively, meaning that none are persistent, i.e. all
;are reset. If you want your variables to persist between matches,
;you need to override state 5900 from common1.cns.
IntPersistIndex = 30
FloatPersistIndex = 20

[Size]
xscale = 1           ;Horizontal scaling factor.
yscale = 1           ;Vertical scaling factor.
ground.back = 25    ;Player width (back, ground)
ground.front = 25    ;Player width (front, ground)
air.back = 20        ;Player width (back, air)
air.front = 20       ;Player width (front, air)
height = 60      ;Height of player (for opponent to jump over)
attack.dist = 120    ;Default attack distance
proj.attack.dist = 90 ;Default attack distance for projectiles
proj.doscale = 0     ;Set to 1 to scale projectiles too
head.pos = -10, -104  ;Approximate position of head
mid.pos = -14, -68    ;Approximate position of midsection
shadowoffset = 0     ;Number of pixels to vertically offset the shadow
draw.offset = 0,0    ;Player drawing offset in pixels (x, y)

[Velocity]
walk.fwd  = 3
walk.back = -3
run.fwd  = 7, 0
run.back = -5.5,-4
jump.neu = 0,-8.9473684
jump.back = -2.5
jump.fwd = 2.5
runjump.back = -4.5,-8.9473684
runjump.fwd = 4.5,-8.9473684
airjump.neu = 0,-8.9473684
airjump.back = -2.55
airjump.fwd = 2.5

[Movement]
airjump.num = 0      ;Number of air jumps allowed (opt)
airjump.height = 35  ;Minimum distance from ground before you can air jump (opt)
yaccel = .4970760    ;Vertical acceleration l
stand.friction = .8375;.818181818181818;85  ;Friction coefficient when standing
crouch.friction = .818181818181818;82 ;Friction coefficient when crouching


[Quotes]
victory1 = " Eu nŃo sou um heroi. Eu nunca fui. \n Sou apenas um velho assassino. \n \n I'm not a hero. I've never been. \n I'm just an old killer."
victory2 = " Eu sou uma sombra, \n nunca nenhuma luz vai brilhar em mim, \n se voce me seguir, nunca vera a luz do dia.  \n \n I am a shadow, \n no light will ever shine on me, if you follow me \n you will never see the light of day."


;---------------------------------------------------------------------------
; Format:
; [Statedef STATENO]
; type = ?      S/C/A/L  stand/crouch/air/liedown
; movetype = ?  I/A/H    idle/attack/gethit
; physics = ?   S/C/A/N  stand/crouch/air/none
; juggle = ?             air juggle points move requires
;
; [State STATENO, ?]     ? - any number you choose
; type = ?
; ...
;---------------------------------------------------------------------------
