# Fundo Metal Slug (320x224)
IMAGE bg_metal_slug "bgs/bg_metal_slug.png" BEST

# Personagens (Animação configurada via FAST)
# Megaman é sprite pequeno (64x64, 4 quadros -> 64x64 cada)
SPRITE spr_megaman "sprites/spr_megaman.png" 8 8 FAST 5 
# Ken é padrão luta (128x128, 4 quadros -> 128x128 cada)
SPRITE spr_ken "sprites/spr_ken.png" 16 16 FAST 5 
# Earthquake e Blackheart (128x128, 4 quadros -> 128x128 cada)
SPRITE spr_earthquake "sprites/spr_earthquake.png" 16 16 FAST 5 
SPRITE spr_blackheart "sprites/spr_blackheart.png" 16 16 FAST 5 
