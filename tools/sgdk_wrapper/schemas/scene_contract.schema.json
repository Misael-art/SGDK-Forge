{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "sgdk_wrapper/schemas/scene_contract.schema.json",
  "title": "SGDK Scene Contract Manifest",
  "description": "Project-level manifest declaring the contract for each scene. Lives at <project_root>/doc/scene-contracts.json. Used by the linter, regression runner, and budget auditor.",
  "type": "object",
  "required": [
    "schema_version",
    "project_profile",
    "scenes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "project_profile": {
      "type": "string",
      "enum": ["lab", "production", "aaa_gate"],
      "description": "Rigor level. lab=relaxed, production=standard, aaa_gate=strict"
    },
    "scenes": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/definitions/scene_entry"
      }
    }
  },
  "additionalProperties": true,
  "definitions": {
    "scene_entry": {
      "type": "object",
      "required": [
        "scene_id",
        "scene_role",
        "boot_mode"
      ],
      "properties": {
        "scene_id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "minLength": 1,
          "maxLength": 64,
          "description": "Unique lowercase identifier for this scene"
        },
        "scene_role": {
          "type": "string",
          "enum": ["menu", "title", "gameplay", "boss", "cutscene", "lab", "debug", "benchmark"],
          "description": "Functional role of the scene"
        },
        "boot_mode": {
          "type": "string",
          "enum": ["debug_menu", "sram_bootstrap", "runtime_flag", "direct_boot", "unsupported"],
          "description": "How this scene can be deterministically reached"
        },
        "capture_frame": {
          "type": "integer",
          "minimum": 0,
          "description": "Frame number at which to capture evidence"
        },
        "warmup_frames": {
          "type": "integer",
          "minimum": 0,
          "description": "Frames to wait before scene is considered stable"
        },
        "required_assets": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Relative paths to assets this scene depends on"
        },
        "visual_priority": {
          "type": "string",
          "enum": ["critical", "high", "normal", "low"],
          "description": "Visual fidelity priority for this scene"
        },
        "palette_policy": {
          "type": "string",
          "description": "Describes palette usage strategy (e.g. 'single_pal0', 'dynamic_fade', 'multi_pal')"
        },
        "budget_profile": {
          "type": "string",
          "description": "Budget class reference (e.g. 'lightweight', 'standard', 'heavy_fx')"
        },
        "effects_active": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of active FX (e.g. 'raster_scroll', 'palette_fade', 'sprite_scaling')"
        },
        "cleanup_required": {
          "type": "boolean",
          "description": "Whether this scene needs explicit cleanup before transitioning"
        },
        "regression_required": {
          "type": "boolean",
          "description": "Whether this scene must have a regression baseline"
        }
      },
      "additionalProperties": true
    }
  }
}
